#!/usr/bin/env bash
#
# clean-image - Strip AI detection metadata from images and convert to JPEG
#
# Removes all EXIF, XMP, IPTC, C2PA, and other metadata that platforms
# like Twitter/X use to detect AI-generated images. Optionally re-encodes
# with slight quality adjustment to defeat pixel-level fingerprinting.
#
# Dependencies: exiftool, ffmpeg (both available via brew)

set -euo pipefail

VERSION="1.0.0"
QUALITY=92
STRIP_ONLY=false
OUTPUT=""
AGGRESSIVE=false

usage() {
    cat <<EOF
clean-image v${VERSION}

Usage: clean-image [OPTIONS] <input-image> [output.jpg]

Strip AI detection metadata from images and convert to JPEG.

Options:
  -q, --quality NUM    JPEG quality 1-100 (default: 92)
  -s, --strip-only     Only strip metadata, don't re-encode (keeps format)
  -a, --aggressive     Aggressive mode: slight gaussian blur + re-encode
                       to defeat pixel-level AI fingerprinting
  -o, --output FILE    Output file path (default: <input>-clean.jpg)
  -h, --help           Show this help
  -v, --version        Show version

Examples:
  clean-image photo.png                     # -> photo-clean.jpg
  clean-image photo.png output.jpg          # -> output.jpg
  clean-image -q 85 photo.webp              # Lower quality, smaller file
  clean-image -a photo.png                  # Aggressive pixel cleaning
  clean-image -s photo.jpg                  # Just strip metadata, keep as-is

What it removes:
  - EXIF metadata (camera, software, AI tool info)
  - XMP metadata (Adobe AI tags, creator tools)
  - IPTC metadata (digital source type)
  - C2PA / Content Credentials (AI provenance data)
  - ICC profiles (optional color profiles)
  - JFIF/APP markers
  - PNG text chunks (ComfyUI, Stable Diffusion params)
EOF
    exit 0
}

version() {
    echo "clean-image v${VERSION}"
    exit 0
}

check_deps() {
    local missing=()
    command -v exiftool >/dev/null 2>&1 || missing+=(exiftool)
    command -v ffmpeg >/dev/null 2>&1 || missing+=(ffmpeg)

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "Error: Missing dependencies: ${missing[*]}" >&2
        echo "Install with: brew install ${missing[*]}" >&2
        exit 1
    fi
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        -q|--quality) QUALITY="$2"; shift 2 ;;
        -s|--strip-only) STRIP_ONLY=true; shift ;;
        -a|--aggressive) AGGRESSIVE=true; shift ;;
        -o|--output) OUTPUT="$2"; shift 2 ;;
        -h|--help) usage ;;
        -v|--version) version ;;
        -*)
            echo "Unknown option: $1" >&2
            echo "Run 'clean-image --help' for usage." >&2
            exit 1
            ;;
        *)
            if [[ -z "${INPUT:-}" ]]; then
                INPUT="$1"
            elif [[ -z "$OUTPUT" ]]; then
                OUTPUT="$1"
            fi
            shift
            ;;
    esac
done

if [[ -z "${INPUT:-}" ]]; then
    echo "Error: No input file specified." >&2
    echo "Run 'clean-image --help' for usage." >&2
    exit 1
fi

if [[ ! -f "$INPUT" ]]; then
    echo "Error: File not found: $INPUT" >&2
    exit 1
fi

check_deps

# Determine output filename
if [[ -z "$OUTPUT" ]]; then
    basename="${INPUT%.*}"
    if [[ "$STRIP_ONLY" == true ]]; then
        ext="${INPUT##*.}"
        OUTPUT="${basename}-clean.${ext}"
    else
        OUTPUT="${basename}-clean.jpg"
    fi
fi

# Create temp file for processing
TMPFILE=$(mktemp /tmp/clean-image.XXXXXX.jpg)
trap 'rm -f "$TMPFILE" "${TMPFILE%.jpg}_pass2.jpg"' EXIT

echo "Processing: $INPUT"

if [[ "$STRIP_ONLY" == true ]]; then
    # Just copy and strip metadata
    cp "$INPUT" "$OUTPUT"
    exiftool -all= -overwrite_original -quiet "$OUTPUT"
    echo "Stripped metadata -> $OUTPUT"
else
    # Step 1: Convert to JPEG with ffmpeg (strips most metadata by default)
    FFMPEG_FILTERS=""
    if [[ "$AGGRESSIVE" == true ]]; then
        # Slight gaussian blur to disrupt pixel-level fingerprints
        # sigma=0.3 is imperceptible but changes pixel values
        FFMPEG_FILTERS="-vf gblur=sigma=0.3"
    fi

    ffmpeg -y -i "$INPUT" \
        $FFMPEG_FILTERS \
        -q:v $(( (100 - QUALITY) * 31 / 100 + 1 )) \
        -map_metadata -1 \
        -fflags +bitexact \
        -flags:v +bitexact \
        "$TMPFILE" 2>/dev/null

    # Step 2: Nuclear metadata strip with exiftool (catches anything ffmpeg missed)
    exiftool -all= -overwrite_original -quiet "$TMPFILE"

    # Step 3: Re-encode one more time to ensure clean JPEG structure
    # This removes any residual APP markers or non-standard segments
    ffmpeg -y -i "$TMPFILE" \
        -q:v $(( (100 - QUALITY) * 31 / 100 + 1 )) \
        -map_metadata -1 \
        -fflags +bitexact \
        -flags:v +bitexact \
        "$OUTPUT" 2>/dev/null

    # Final strip for paranoia
    exiftool -all= -overwrite_original -quiet "$OUTPUT"

    if [[ "$AGGRESSIVE" == true ]]; then
        echo "Aggressive clean -> $OUTPUT"
    else
        echo "Cleaned -> $OUTPUT"
    fi
fi

# Show before/after comparison
INPUT_SIZE=$(stat -f%z "$INPUT" 2>/dev/null || stat -c%s "$INPUT" 2>/dev/null)
OUTPUT_SIZE=$(stat -f%z "$OUTPUT" 2>/dev/null || stat -c%s "$OUTPUT" 2>/dev/null)
INPUT_META=$(exiftool "$INPUT" 2>/dev/null | wc -l | tr -d ' ')
OUTPUT_META=$(exiftool "$OUTPUT" 2>/dev/null | wc -l | tr -d ' ')

echo ""
echo "  Input:  $(( INPUT_SIZE / 1024 )) KB | ${INPUT_META} metadata fields"
echo "  Output: $(( OUTPUT_SIZE / 1024 )) KB | ${OUTPUT_META} metadata fields"
echo "  Done!"
